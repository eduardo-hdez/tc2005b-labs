<%- include('../includes/header') %>

<h2 class="title is-4">Users</h2>

<% if (!users || users.length === 0) { %>
  <div class="notification is-warning is-light">
    <p><em>No users found.</em></p>
  </div>
<% } else { %>
  <div class="table-container">
    <table class="table is-striped is-hoverable is-fullwidth">
      <thead>
        <tr>
          <th>#</th>
          <th>Username</th>
          <th>Name</th>
          <th>Created At</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><strong><%= user.username %></strong></td>
            <td><%= user.name %></td>
            <td><%= user.created_at ? new Date(user.created_at).toLocaleDateString() : '-' %></td>
            <td>
              <div class="buttons are-small">
                <% if (privilegios.some(p => p.name_privilege === 'Assing roles')) { %>
                  <a class="button is-info is-outlined" href="/users/<%= user.username %>/assign-role">Roles</a>
                <% } %>
                <% if (privilegios.some(p => p.name_privilege === 'Manage users') && user.username !== username) { %>
                  <form action="/users/<%= user.username %>/delete" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="button is-danger is-outlined" type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../includes/footer') %>
