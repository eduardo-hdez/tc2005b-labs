<%- include('../includes/header') %>

<form action="/tasks/<%= task.id %>/edit" method="POST">
    <label for="title">Title:</label>
    <input type="text" id="title" name="title" value="<%= task.name %>" required>
    <br><br>
    <label for="description">Description:</label>
    <input type="text" id="description" name="description" value="<%= task.description %>" required>
    <br><br>
    <button type="submit">Update Task</button>
    <a href="/tasks"><button type="button">Cancel</button></a>
</form>

<%- include('../includes/footer') %>
