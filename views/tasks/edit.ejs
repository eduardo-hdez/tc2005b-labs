<%- include('../includes/header') %>

<h2>Edit Task</h2>

<form action="/tasks/<%= task.id %>/edit" method="POST">
  <fieldset>
    <legend>Task Details</legend>

    <p>
      <label for="title"><strong>Name:</strong></label><br />
      <input type="text" id="title" name="title" size="40" value="<%= task.name %>" required />
    </p>

    <p>
      <label for="description"><strong>Description:</strong></label><br />
      <textarea id="description" name="description" rows="4" cols="40" required><%= task.description %></textarea>
    </p>

    <p>
      <button type="submit">Update Task</button>
      <a href="/tasks">Cancel</a>
    </p>
  </fieldset>
</form>

<%- include('../includes/footer') %>
