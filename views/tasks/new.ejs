<%- include('../includes/header') %>

<h2>Create New Task</h2>

<form action="/tasks/new" method="POST">
  <fieldset>
    <legend>Task Details</legend>

    <p>
      <label for="title"><strong>Title:</strong></label><br />
      <input type="text" id="title" name="title" size="40" placeholder="Enter task title" required />
    </p>

    <p>
      <label for="description"><strong>Description:</strong></label><br />
      <textarea id="description" name="description" rows="4" cols="40" placeholder="Enter task description" required></textarea>
    </p>

    <p>
      <button type="submit">Save Task</button>
      <a href="/tasks">Cancel</a>
    </p>
  </fieldset>
</form>

<%- include('../includes/footer') %>
