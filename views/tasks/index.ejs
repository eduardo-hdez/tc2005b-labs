<%- include('../includes/header') %>

<div class="level">
  <div class="level-left">
    <h2 class="title is-4">Tasks (<%= tasks.length %>)</h2>
  </div>
  <div class="level-right">
    <a class="button is-success" href="/tasks/new-task">+ New Task</a>
  </div>
</div>

<% if (tasks.length === 0) { %>
  <div class="notification is-warning is-light">
    <p><em>No tasks yet.</em> <a href="/tasks/new-task">Create one!</a></p>
  </div>
<% } else { %>
  <div class="table-container">
    <table class="table is-striped is-hoverable is-fullwidth">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Description</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% tasks.forEach((task, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><strong><%= task.title %></strong></td>
            <td><%= task.description %></td>
            <td><a class="button is-small is-info is-outlined" href="/tasks/<%= task.id_task %>/edit-task">Edit</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../includes/footer') %>
