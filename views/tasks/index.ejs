<%- include('../includes/header') %>

<a href="/tasks/new"><button>New task</button></a>
<div>
  <% for (let task of tasks) { %>
    <div>
      <h2><%= task.name %></h2>
      <p><%= task.description %></p>
      <a href="/tasks/<%= task.id %>/edit"><button>Edit</button></a>
    </div>
  <% } %>
</div>

<%- include('../includes/footer') %>
