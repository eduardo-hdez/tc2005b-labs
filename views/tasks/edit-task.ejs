<%- include('../includes/header') %>

<h2 class="title is-4">Edit Task</h2>

<div class="box">
  <form action="/tasks/<%= task.id_task %>/edit-task" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="field">
      <label class="label" for="title">Name</label>
      <div class="control">
        <input class="input" type="text" id="title" name="title" value="<%= task.title %>" required />
      </div>
    </div>

    <div class="field">
      <label class="label" for="description">Description</label>
      <div class="control">
        <textarea class="textarea" id="description" name="description" rows="4" required><%= task.description %></textarea>
      </div>
    </div>

    <div class="field is-grouped">
      <div class="control">
        <button class="button is-success" type="submit">Update Task</button>
      </div>
      <div class="control">
        <a class="button is-light" href="/tasks">Cancel</a>
      </div>
    </div>
  </form>
</div>

<%- include('../includes/footer') %>
